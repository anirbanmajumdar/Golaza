# Copy to .env and edit for production (docker compose reads it automatically).

# REQUIRED in prod — sign your JWTs with a long random secret:
WCB_SECRET_KEY=please-generate-a-long-random-string

# Email OTP delivery. Leave WCB_SMTP_HOST blank to run in DEV MODE
# (the 6-digit code is logged and returned in the API response).
# Gmail example: create an App Password, then:
WCB_SMTP_HOST=
WCB_SMTP_PORT=587
WCB_SMTP_USER=youraddress@gmail.com
WCB_SMTP_PASSWORD=your-app-password
WCB_SMTP_FROM=GOLAZO 2026 <youraddress@gmail.com>

# Set to false in production so codes are NEVER returned over the API:
WCB_DEV_ECHO_OTP=true
